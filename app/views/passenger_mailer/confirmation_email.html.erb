<style>

*,
*::before,
*::after {
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

main {
  background-color: hsl(from grey h s calc(l + 15));
}

</style>

<main>
  <h1>
    You have booked your ticket, <%= @passenger.name %>.
  </h1>

  <hr>

  <p>
    To see the booking details, follow this link: <%= link_to "Booking", booking_url(@passenger.booking) %>
  </p>
</main>
